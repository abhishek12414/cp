{
  "kind": "collectionType",
  "collectionName": "carts",
  "info": {
    "singularName": "cart",
    "pluralName": "carts",
    "displayName": "Cart",
    "description": "User's shopping cart, linked to products via CartItems for quantities. Ties into Product/Brand for e-com."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "cart"
    },
    "cartItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cart-item.cart-item",
      "mappedBy": "cart"
    },
    "total": {
      "type": "decimal",
      "default": 0,
      "min": 0,
      "description": "Computed total (sum of item prices * qty); update via lifecycle"
    }
  }
}
